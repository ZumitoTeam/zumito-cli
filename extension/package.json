{
  "name": "zumito-extension",
  "displayName": "Zumito CLI Extension",
  "description": "VSCode extension to use Zumito CLI utilities within the editor.",
  "version": "0.0.3",
  "publisher": "FernandoMerino",
  "engines": {
    "vscode": "^1.70.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "commands": [
      {
        "command": "zumito-cli.createProject",
        "title": "Zumito: Create Project"
      },
      {
        "command": "zumito-cli.createModule",
        "title": "Zumito: Create Module (Bot)"
      },
      {
        "command": "zumito-cli.createEmbedBuilder",
        "title": "Zumito: Create Embed Builder"
      },
      {
        "command": "zumito-cli.createActionRowBuilder",
        "title": "Zumito: Create Action Row Builder"
      },
      {
        "command": "zumito-cli.injectService",
        "title": "Zumito: Inject Service"
      },
      {
        "command": "zumito-cli.runDev",
        "title": "Zumito: Run Dev"
      },
      {
        "command": "zumito-cli.runDebug",
        "title": "Zumito: Run Debug"
      },
      {
        "command": "zumito-cli.modules.configure",
        "title": "Zumito: Configure Module"
      },
      {
        "command": "zumito-cli.modules.install",
        "title": "Zumito: Install Module"
      },
      {
        "command": "zumito-cli.modules.uninstall",
        "title": "Zumito: Uninstall Module"
      },
      {
        "command": "zumito-cli.createCommand",
        "title": "Zumito: Create Command"
      },
      {
        "command": "zumito-cli.editTranslation",
        "title": "Zumito: Edit translation"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "zumito-cli.createModule",
          "when": "explorerResourceIsFolder && resourceFilename == modules",
          "group": "zumito"
        },
        {
          "command": "zumito-cli.createCommand",
          "when": "explorerResourceIsFolder && resourceFilename == commands || !explorerResourceIsFolder && resourceDirname =~ /commands$/",
          "group": "zumito"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "vsce": "^2.15.0"
  },
  "dependencies": {}
}
